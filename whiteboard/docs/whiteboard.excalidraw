      "text": "State model\n    byId: \n        id1: \n            isClicked\n            isTile\n    allTiles: [id1, id2.... ]\n    clickStack: [id2, id1.... ]\n    isGameOver: boolean\n\n\nHook:\n    getState\n    handleClick\n    resetWithDelay\n    restartGame\n\n\nFile Folder\nComponents\n    Grid\n    Cell\nHooks\n    index.js\nCore\n    engine.js",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "State model\n    byId: \n        id1: \n            isClicked\n            isTile\n    allTiles: [id1, id2.... ]\n    clickStack: [id2, id1.... ]\n    isGameOver: boolean\n\n\nHook:\n    getState\n    handleClick\n    resetWithDelay\n    restartGame\n\n\nFile Folder\nComponents\n    Grid\n    Cell\nHooks\n    index.js\nCore\n    engine.js",
      "autoResize": true,
      "lineHeight": 1.25
    },
